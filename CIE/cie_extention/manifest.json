{
  "manifest_version": 3,
  "name": "CIE Agent - Universal Bookmarker",
  "version": "2.0.0",
  "description": "Save content from ANY website - LinkedIn, Medium, Twitter, Blogs, Research Papers & more",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}